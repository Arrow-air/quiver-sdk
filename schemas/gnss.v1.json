{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Arrow-air/quiver-sdk/schemas/gnss/v1.json",
  "title": "quiver/gnss/v1",
  "type": "object",
  "required": ["timestamp", "fix_type", "latitude_deg", "longitude_deg"],
  "properties": {
    "timestamp":         {"type": "number"},
    "fix_type":          {"type": "string", "enum": ["none", "2d", "3d", "dgps", "rtk_float", "rtk_fixed"]},
    "latitude_deg":      {"type": "number", "minimum": -90, "maximum": 90},
    "longitude_deg":     {"type": "number", "minimum": -180, "maximum": 180},
    "altitude_m":        {"type": "number"},
    "satellites":        {"type": "integer", "minimum": 0},
    "hdop":              {"type": "number", "minimum": 0},
    "vdop":              {"type": "number", "minimum": 0},
    "velocity_ned_m_s":  {"type": "array", "items": {"type": "number"}, "minItems": 3, "maxItems": 3}
  }
}
