{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Arrow-air/quiver-sdk/schemas/actuator_status/v1.json",
  "title": "quiver/actuator_status/v1",
  "type": "object",
  "required": ["timestamp", "actuator_id", "state"],
  "properties": {
    "timestamp":    {"type": "number"},
    "actuator_id":  {"type": "integer"},
    "state":        {"type": "string", "enum": ["idle", "running", "error", "unknown"]},
    "position_pct": {"type": "number", "minimum": 0, "maximum": 100},
    "power_w":      {"type": "number", "minimum": 0},
    "error":        {"type": ["string", "null"]}
  }
}
